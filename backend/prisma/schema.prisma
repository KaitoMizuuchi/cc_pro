generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  books     Book[]

  @@map("users")
}

model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  employees Employee[]

  @@map("departments")
}

model Employee {
  id           String         @id @default(cuid())
  lastName     String         @map("last_name")
  firstName    String         @map("first_name")
  email        String         @unique
  phone        String?
  departmentId String         @map("department_id")
  position     String
  hireDate     DateTime       @map("hire_date")
  status       EmployeeStatus @default(ACTIVE)
  note         String?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  department     Department      @relation(fields: [departmentId], references: [id])
  ledProjects    Project[]       @relation("ProjectLeader")
  projectMembers ProjectMember[]
  borrowedBooks  Book[]          @relation("BookBorrower")

  @@map("employees")
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  RETIRED
}

model Project {
  id          String          @id @default(cuid())
  name        String          @unique
  description String
  leaderId    String          @map("leader_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  leader      Employee        @relation("ProjectLeader", fields: [leaderId], references: [id])
  members     ProjectMember[]

  @@map("projects")
}

model ProjectMember {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  employeeId String   @map("employee_id")
  createdAt  DateTime @default(now()) @map("created_at")
  project    Project  @relation(fields: [projectId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@unique([projectId, employeeId])
  @@map("project_members")
}

enum BookStatus {
  STORED
  LENDING
}

model Book {
  id            String     @id @default(cuid())
  isbn          String
  title         String
  author        String
  category      String?
  coverImageUrl String?    @map("cover_image_url")
  status        BookStatus @default(STORED)
  registrantId  String     @map("registrant_id")
  borrowerId    String?    @map("borrower_id")
  note          String?
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  registrant    User       @relation(fields: [registrantId], references: [id])
  borrower      Employee?  @relation("BookBorrower", fields: [borrowerId], references: [id])

  @@map("books")
}
